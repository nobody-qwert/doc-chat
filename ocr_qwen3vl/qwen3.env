# Qwen3-VL OCR module settings (provider-only)

# Enable/disable inference. Set QWEN_VL_STUB=1 to return placeholder text without starting llama-cpp.
QWEN_VL_STUB=0

# Qwen3.6 is hosted by the shared llm-inference service. This container only
# renders documents and forwards image prompts to that endpoint.
QWEN_VL_MANAGED_SERVER=false

# OpenAI-compatible vision endpoint exposed by the shared LLM container.
QWEN_VL_BASE_URL=http://llm-inference:8000/v1
QWEN_VL_MODEL_ALIAS=Qwen3.6-35B-A3B

# OCR behavior
QWEN_VL_PROMPT=You are an OCR system. Extract all readable text from the image. Return clean Markdown in reading order. If there are tables, render them as Markdown tables. Do not add commentary. Do NOT wrap your output in code fences or markdown code blocks - output raw markdown text directly. Do NOT include image URLs or markdown image syntax like ![](url) - if you see icons or images, describe them briefly in text or skip them.
QWEN_VL_TEMPERATURE=0.1
QWEN_VL_TOP_K=20
QWEN_VL_TOP_P=0.95
QWEN_VL_REPEAT_PENALTY=1.1

# PDF rendering defaults
QWEN_VL_RENDER_DPI=200
QWEN_VL_RENDER_MAX_DIM=2560

# Save rendered page images to disk (for debugging/archival). Default: false
QWEN_VL_SAVE_IMAGES=false

# Lifecycle
QWEN_VL_WARMUP_ON_STARTUP=false
QWEN_VL_SERVER_SHUTDOWN_TIMEOUT=30
QWEN_VL_REQUEST_TIMEOUT=180

# Formatting
QWEN_VL_PAGE_SEPARATOR=\n\n---\n\n

QWEN_VL_AUTO_LOAD=false
