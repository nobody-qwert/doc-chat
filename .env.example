COMPOSE_PROFILES=qwen3_vl

# Active LLM endpoint (points backend to the llm-inference service)
LLM_ENDPOINT=llm-inference
LLM_CONTROL_PORT=9000
LLM_CONTEXT_SIZE=10000
LLM_BATCH_SIZE=512
LLM_BASE_URL=http://${LLM_ENDPOINT}:8000/v1
LLM_CONTROL_URL=http://${LLM_ENDPOINT}:9000/control
LLM_SERVER_SHUTDOWN_TIMEOUT=30
LOG_LEVEL=INFO
LLM_TOKENIZER_ID=Qwen/Qwen3-30B-A3B
LLM_TEMPERATURE=0.8
LLM_TOP_P=0.2
LLM_TOP_K=20
LLM_MIN_P=0.05
LLM_REPEAT_PENALTY=1.1
LLM_MODEL=Qwen3-30B-A3B-Instruct-2507-Q4_K_M


CHAT_COMPLETION_MAX_TOKENS=2048
CHAT_COMPLETION_RESERVE=2048


AGENTIC_MAX_SUBQUERIES=5
AGENTIC_SHORT_DOC_CHUNK_LIMIT=20
AGENTIC_SHORT_DOC_TOKEN_LIMIT=9000
AGENTIC_EXPANSION_CHUNKS_BEFORE=10
AGENTIC_EXPANSION_CHUNKS_AFTER=10
AGENTIC_MAX_EXPANDED_CHUNKS=20
AGENTIC_EXPANDED_CHAR_MULTIPLIER=20
AGENTIC_MIN_EXPANDED_CHARS=4000
AGENTIC_MAX_EXPANDED_CHARS=5000
AGENTIC_INSPECTOR_MAX_ITEMS=10


GPU_PHASE_TIMEOUT=60
LLM_READY_TIMEOUT=180

# Embeddings
EMBEDDING_BASE_URL=http://embed:8080/v1
EMBEDDING_MODEL=text-embedding-qwen3-0.6b
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=1
EMBEDDING_TOKENIZER_ID=Qwen/Qwen3-Embedding-0.6B
EMBED_MODEL_DIR=./models/embed
EMBED_MODEL_FILE=Qwen3-Embedding-0.6B-Q8_0.gguf
EMBED_CONTEXT_SIZE=2048


BACKEND_PORT=8000
FRONTEND_PORT=5173

# Shared app data root and subdirectories
HOST_APP_DATA=./app_data
APP_DATA_ROOT=/app_data
DATA_DIR=${APP_DATA_ROOT}/docs
INDEX_DIR=${APP_DATA_ROOT}/runtime
DOC_STORE_PATH=${APP_DATA_ROOT}/rag_meta.db
OCR_OUTPUT_DIR=${INDEX_DIR}/ocr_outputs
OCR_INCOMING_DIR=${INDEX_DIR}/incoming
OCR_WARMUP_DIR=${INDEX_DIR}/warmup

# Parser controls
# OCR provider selection via Docker Compose profiles:
#   docker compose --profile qwen3 up   → uses Qwen3-VL OCR (set OCR_PARSER_KEY=qwen3_vl)
#   docker compose --profile mineru up  → uses MinerU OCR   (set OCR_PARSER_KEY=mineru)
# Make sure OCR_PARSER_KEY matches your chosen profile!
OCR_PARSER_KEY=qwen3_vl
OCR_MODULE_URL=http://ocr-module:8000
OCR_CONTROL_URL=http://ocr-module:8000/control
OCR_MODULE_TIMEOUT=1200
OCR_STATUS_POLL_INTERVAL=5
CHUNK_SIZE=200
CHUNK_OVERLAP=60

# Provider-specific OCR settings live in:
# - `ocr_qwen3vl/qwen3.env` (Qwen3-VL)
# - `ocr_mineru/mineru.env` (MinerU)

# Retrieval controls
MIN_CONTEXT_SIMILARITY=0.50
MIN_KEYWORD_SCORE=0.5
TRANSFORMERS_SPEC=transformers>=4.40
VITE_ENABLE_INVOICE_EXTRACTION=false
DIAGNOSTICS_URL=http://diagnostics:9001

# Optional: set 1 to fetch model weights at build time (Docker build must have network access)
PREFETCH_MODELS=0

# llama-cpp-python build controls (useful when a new model architecture lands upstream)
LLAMA_CPP_PYTHON_REF=main
# Bump this number to force Docker to rebuild the llama-cpp-python layer even if the ref is unchanged.
LLAMA_CPP_PYTHON_CACHE_BUST=1

# Host ports
LLM_HOST_PORT=8010
EMBED_HOST_PORT=8011
DIAGNOSTICS_PORT=9001
DIAGNOSTICS_HOST_PORT=9001
