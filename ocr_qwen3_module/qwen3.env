# Qwen3-VL OCR module settings (provider-only)

# Enable/disable inference. Set QWEN_VL_STUB=1 to return placeholder text without starting llama-cpp.
QWEN_VL_STUB=0

# When true, this container starts/stops the llama server process via QWEN_VL_SERVER_CMD.
# When false, the container will call an external OpenAI-compatible endpoint at QWEN_VL_BASE_URL.
QWEN_VL_MANAGED_SERVER=true

# The OCR module will start/stop a local llama_cpp.server process and call it via this base URL.
QWEN_VL_BASE_URL=http://127.0.0.1:8001/v1
QWEN_VL_API_KEY=local-ocr
QWEN_VL_MODEL_ALIAS=qwen3_vl

# OCR behavior
QWEN_VL_PROMPT=You are an OCR system. Extract all readable text from the image. Return clean Markdown in reading order. If there are tables, render them as Markdown tables. Do not add commentary. Do NOT wrap your output in code fences or markdown code blocks - output raw markdown text directly.
QWEN_VL_TEMPERATURE=0.1
QWEN_VL_TOP_K=20
QWEN_VL_TOP_P=0.95
QWEN_VL_REPEAT_PENALTY=1.1

# PDF rendering defaults
QWEN_VL_RENDER_DPI=300
QWEN_VL_RENDER_MAX_DIM=4096

# Save rendered page images to disk (for debugging/archival). Default: false
QWEN_VL_SAVE_IMAGES=false

# Lifecycle
QWEN_VL_WARMUP_ON_STARTUP=false
QWEN_VL_SERVER_SHUTDOWN_TIMEOUT=30
QWEN_VL_REQUEST_TIMEOUT=180

# Formatting
QWEN_VL_PAGE_SEPARATOR=\n\n---\n\n

QWEN_VL_AUTO_LOAD=false

QWEN_VL_SERVER_CMD=llama-server --model /models/vl/Qwen3-VL-30B-A3B-Instruct-Q4_K_M.gguf --mmproj /models/vl/mmproj-Qwen3-VL-30B-A3B-Instruct-F16.gguf --alias qwen3_vl --host 0.0.0.0 --port 8001 --n-gpu-layers -1 --flash-attn on --mlock --api-key local-ocr -c 8192 --ubatch-size 256 --batch-size 256 --parallel 1 -kvu
