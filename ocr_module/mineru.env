# MinerU-only OCR module settings (kept out of root .env so OCR providers can be swapped cleanly)
MINERU_DEVICE_MODE=cuda
MINERU_PARSE_METHOD=ocr
MINERU_LANG=en
MINERU_TABLE_ENABLE=true
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_MERGE_ENABLE=true
MINERU_WARMUP_ON_STARTUP=true

# MinerU caches (optional but recommended to persist under app_data volume)
HF_HOME=/app_data/runtime/caches/hf
TRANSFORMERS_CACHE=/app_data/runtime/caches/hf
ULTRALYTICS_HOME=/app_data/runtime/caches/ultralytics

# MinerU / torch tuning
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
